{
  "entities": {
    "User": {
      "title": "User",
      "description": "Base user profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "userType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "StudentInterest": {
      "title": "StudentInterest",
      "description": "Student's tuition inquiry.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "TeacherInterest": {
      "title": "TeacherInterest",
      "description": "Teacher's specialty profile.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "subjects": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "MatchProposal": {
      "title": "MatchProposal",
      "description": "Matching record between student and teacher.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "Platform event notification.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "read": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/matchProposals/{matchId}": {
      "schema": { "$ref": "#/backend/entities/MatchProposal" },
      "description": "Match proposals."
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/backend/entities/Notification" },
      "description": "System and user notifications."
    },
    "/systemLogs/{logId}": {
      "schema": "object",
      "description": "Admin activity logs."
    }
  }
}