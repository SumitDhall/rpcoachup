
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a registered user account on the RP Coach-Up platform, serving as a base for both students and teachers.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "userType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "firstName", "lastName", "userType", "createdAt", "updatedAt"]
    },
    "StudentInterest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StudentInterest",
      "type": "object",
      "description": "Stores the specific subject and topic interests submitted by a student.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string" },
        "submissionDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "studentName", "subject", "submissionDate", "status"]
    },
    "TeacherInterest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TeacherInterest",
      "type": "object",
      "description": "Stores the teaching interests and availability submitted by a teacher.",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "subjects": { "type": "string" },
        "status": { "type": "string" },
        "submissionDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "teacherId", "teacherName", "submissionDate", "status"]
    },
    "Feedback": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Feedback",
      "type": "object",
      "description": "Represents user feedback about the platform or teachers.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userType": { "type": "string", "enum": ["Student", "Teacher"] },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "teacherName": { "type": "string", "description": "Optional: Name of the teacher being reviewed by a student." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "userType", "rating", "comment", "createdAt"]
    },
    "Notification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notification",
      "type": "object",
      "description": "Represents a system notification record for the administrator dashboard.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "type", "subject", "body", "timestamp"]
    },
    "MatchProposal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MatchProposal",
      "type": "object",
      "description": "Represents a proposed match between a student and a teacher.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "studentName": { "type": "string" },
        "assignedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["id", "studentId", "teacherId", "assignedAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores core user profile details."
        }
      },
      {
        "path": "/studentInterests/{id}",
        "definition": {
          "entityName": "StudentInterest",
          "schema": { "$ref": "#/backend/entities/StudentInterest" },
          "description": "Stores individual student interest submissions."
        }
      },
      {
        "path": "/teacherInterests/{id}",
        "definition": {
          "entityName": "TeacherInterest",
          "schema": { "$ref": "#/backend/entities/TeacherInterest" },
          "description": "Stores individual teacher interest submissions."
        }
      },
      {
        "path": "/feedback/{id}",
        "definition": {
          "entityName": "Feedback",
          "schema": { "$ref": "#/backend/entities/Feedback" },
          "description": "Stores user feedback and testimonials."
        }
      },
      {
        "path": "/notifications/{id}",
        "definition": {
          "entityName": "Notification",
          "schema": { "$ref": "#/backend/entities/Notification" },
          "description": "Stores system notifications for admins."
        }
      },
      {
        "path": "/matchProposals/{id}",
        "definition": {
          "entityName": "MatchProposal",
          "schema": { "$ref": "#/backend/entities/MatchProposal" },
          "description": "Stores admin-created matches."
        }
      },
      {
        "path": "/roles_admin/{adminId}",
        "definition": {
          "entityName": "AdminRole",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Sentinel collection for admin role verification."
        }
      }
    ]
  }
}
