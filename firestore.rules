
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- GLOBAL READ ACCESS ---
    // Broad read access for authenticated users to ensure redirection and dashboard listing queries work.
    match /{path=**} {
      allow read: if isSignedIn();
    }

    // --- SPECIFIC WRITE RULES ---
    // Maintain strict write security to ensure data integrity and privacy.

    match /users/{userId} {
      // Users can manage their own base profile. Admins have full control.
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Allow initial creation during registration
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Nested role-specific profiles
      match /studentProfile/{profileId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) || isAdmin();
      }

      match /teacherProfile/{profileId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /studentInterests/{studentInterestId} {
      // Explicitly allow reading for authenticated users to support dashboard queries
      allow read: if isSignedIn();
      // Any signed-in user can submit an interest.
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /teacherInterests/{teacherInterestId} {
      // Explicitly allow reading for authenticated users to support dashboard queries
      allow read: if isSignedIn();
      // Any signed-in teacher can submit their profile/interests.
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      // Users create notifications (on registration/interest), admins manage them.
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /matchProposals/{matchProposalId} {
      // Authenticated users should be able to see their matches.
      allow read: if isSignedIn();
      // Only admins can create and manage matches between students and teachers.
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      // Needed for the isAdmin() exists() check to work reliably.
      allow read: if isSignedIn();
      // Security sensitive: only existing admins can designate new admins.
      allow write: if isAdmin();
    }

    match /systemLogs/{logId} {
      // System logs are for administrative audit trails.
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    match /feedback/{feedbackId} {
      // Any user can provide feedback.
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}
