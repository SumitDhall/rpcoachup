
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();

      match /studentProfile/{profileId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId);
      }

      match /teacherProfile/{profileId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /studentInterests/{studentInterestId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }

    match /teacherInterests/{teacherInterestId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read, list, update, delete: if isAdmin();
    }

    match /systemLogs/{logId} {
      allow create: if isAdmin();
      allow read, list: if isAdmin();
    }

    match /matchProposals/{matchProposalId} {
      allow get, list: if isAdmin() || (isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.teacherId == request.auth.uid));
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }
    
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read, list, update, delete: if isAdmin();
    }
  }
}
