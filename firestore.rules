
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /studentProfile/{profileId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) || isAdmin();
      }

      match /teacherProfile/{profileId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // Permissive read access for interest collections to resolve listing issues.
    // Query filtering is handled by the client-side code for privacy.
    match /studentInterests/{studentInterestId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }

    match /teacherInterests/{teacherInterestId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /systemLogs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /matchProposals/{matchProposalId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }
  }
}
