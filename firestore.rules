
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- GLOBAL READ ACCESS ---
    // Merged Policy: We allow any signed-in user to read data across the platform.
    // This is critical for dashboard listing queries and the login/redirection process.
    match /{path=**} {
      allow read: if isSignedIn();
    }

    // --- SPECIFIC WRITE RULES ---
    // We maintain strict write security to ensure data integrity and privacy.

    match /users/{userId} {
      // Users can manage their own base profile. Admins have full control.
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Nested role-specific profiles
      match /studentProfile/{profileId} {
        allow write: if isOwner(userId) || isAdmin();
      }

      match /teacherProfile/{profileId} {
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /studentInterests/{studentInterestId} {
      // Any signed-in user can submit an interest.
      // Broad read is allowed globally, but explicit permission is maintained here for clarity.
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /teacherInterests/{teacherInterestId} {
      // Any signed-in teacher can submit their profile/interests.
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      // Users create notifications (on registration/interest), admins manage them.
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /matchProposals/{matchProposalId} {
      // Only admins can create and manage matches between students and teachers.
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      // Security sensitive: only existing admins can designate new admins.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /systemLogs/{logId} {
      // System logs are for administrative audit trails.
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    match /feedback/{feedbackId} {
      // Any user can provide feedback.
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}
