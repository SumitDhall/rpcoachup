
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- GLOBAL READ ACCESS ---
    // Broad read access for ANY authenticated user to prevent dashboard listing and redirection errors.
    // This handles the "list" operations that were previously failing.
    match /{path=**} {
      allow read: if isSignedIn();
    }

    // --- SPECIFIC WRITE RULES ---
    // Rules for individual collections to maintain data integrity.

    match /users/{userId} {
      // Users can write their own base profile.
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /studentInterests/{studentInterestId} {
      // Allow any signed-in user to list/get interests to support matching and dashboard views.
      allow read: if isSignedIn(); 
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /teacherInterests/{teacherInterestId} {
      // Allow any signed-in user to list/get interests.
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /matchProposals/{matchProposalId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /systemLogs/{logId} {
      allow create: if isSignedIn();
      allow read, delete: if isAdmin();
    }
    
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read, delete: if isAdmin();
    }
  }
}
