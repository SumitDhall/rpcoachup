
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
      
      match /studentProfile/studentProfile {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /teacherProfile/teacherProfile {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /studentInterests/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /teacherInterests/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /feedback/{id} {
      allow read: if true; // Publicly readable for the About Us page
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /notifications/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /roles_admin/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /matchProposals/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /systemLogs/{id} {
      allow read, write: if isAdmin();
    }
  }
}
