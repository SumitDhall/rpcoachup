
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDataOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isImmutable(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && isImmutable('id') && isImmutable('userType');
      allow delete: if isAdmin();

      match /studentProfile/{profileId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId);
      }

      match /teacherProfile/{profileId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /studentInterests/{studentInterestId} {
      allow get: if isAdmin() || isDataOwner(resource.data.studentId);
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100); 
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin() || isDataOwner(resource.data.studentId);
    }

    match /teacherInterests/{teacherInterestId} {
      allow get: if isAdmin() || isDataOwner(resource.data.teacherId);
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100);
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isAdmin() || isDataOwner(resource.data.teacherId);
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read, list, update, delete: if isAdmin();
    }

    match /programs/{programId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /matchProposals/{matchProposalId} {
      allow get, list: if isAdmin() || isDataOwner(resource.data.studentId) || isDataOwner(resource.data.teacherId);
      allow create, update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow get: if isAdmin() || isDataOwner(resource.data.userProfileId);
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userProfileId == request.auth.uid;
      allow update, delete: if isAdmin() || isDataOwner(resource.data.userProfileId);
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }
  }
}
