
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- GLOBAL READ ACCESS ---
    // This recursive match ensures that any signed-in user can perform read/list operations.
    // The UI is responsible for filtering data (e.g., showing only a student's own interests).
    match /{path=**} {
      allow read: if isSignedIn();
    }

    // --- SPECIFIC WRITE RULES ---
    // We maintain strict write security to ensure data integrity.

    match /users/{userId} {
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /studentProfile/{profileId} {
        allow write: if isOwner(userId) || isAdmin();
      }

      match /teacherProfile/{profileId} {
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /studentInterests/{studentInterestId} {
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /teacherInterests/{teacherInterestId} {
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /matchProposals/{matchProposalId} {
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow write: if isAdmin();
    }

    match /systemLogs/{logId} {
      allow create: if isSignedIn();
    }
    
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
    }
  }
}
