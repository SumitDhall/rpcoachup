
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- GLOBAL READ ACCESS ---
    // Broad read access for ANY authenticated user to prevent dashboard listing and redirection errors.
    match /{path=**} {
      allow read: if isSignedIn();
    }

    // --- SPECIFIC WRITE RULES ---
    // Strict write security to ensure data integrity.

    match /users/{userId} {
      // Users can write their own base profile.
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      match /studentProfile/{profileId} {
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      match /teacherProfile/{profileId} {
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /studentInterests/{studentInterestId} {
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /teacherInterests/{teacherInterestId} {
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /matchProposals/{matchProposalId} {
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow write: if isAdmin();
    }

    match /systemLogs/{logId} {
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}
